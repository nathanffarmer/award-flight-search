{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/require-simplify-before-commit.sh",
						"if": "Bash(git commit*)"
					}
				]
			}
		]
	}
}
